{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "src/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 10 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}