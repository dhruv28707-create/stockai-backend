{
  "name": "android-ai-stock-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js + TypeScript backend scaffold for a single-user Android AI Stock Assistant.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx vercel dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.10.0",
    "yahoo-finance2": "^2.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
