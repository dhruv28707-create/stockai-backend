{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "node_modules/yahoo-finance2/**",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "0 4,7 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}